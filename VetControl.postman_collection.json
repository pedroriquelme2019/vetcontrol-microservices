{
  "info": {
    "name": "VetControl Microservices - Postman Collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "token",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth - Login Admin",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "auth",
            "login"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin123\"\n}"
        }
      }
    },
    {
      "name": "Clientes - Listar",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": "{{baseUrl}}/api/v1/clientes"
      }
    },
    {
      "name": "Clientes - Crear",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "{{baseUrl}}/api/v1/clientes",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"rut\": \"12345678-9\",\n  \"nombre\": \"Pedro Riquelme\",\n  \"telefono\": \"+56912345678\",\n  \"correo\": \"pedro@example.com\",\n  \"direccion\": \"Santiago\"\n}"
        }
      }
    },
    {
      "name": "Mascotas - Crear",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "{{baseUrl}}/api/v1/mascotas",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"clienteId\": 1,\n  \"nombre\": \"Rocky\",\n  \"especie\": \"Perro\",\n  \"raza\": \"Mestizo\",\n  \"edad\": 3,\n  \"sexo\": \"Macho\",\n  \"peso\": 12.5,\n  \"microchip\": \"CHIP-123\"\n}"
        }
      }
    },
    {
      "name": "Citas - Crear",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "{{baseUrl}}/api/v1/citas",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"mascotaId\": 1,\n  \"veterinarioId\": 1,\n  \"fecha\": \"2026-06-01\",\n  \"hora\": \"10:30:00\",\n  \"motivo\": \"Consulta general\"\n}"
        }
      }
    },
    {
      "name": "Ventas - Crear",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "{{baseUrl}}/api/v1/ventas",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"clienteId\": 1,\n  \"medioPago\": \"DEBITO\",\n  \"detalles\": [\n    {\n      \"productoId\": 1,\n      \"cantidad\": 2\n    }\n  ]\n}"
        }
      }
    },
    {
      "name": "Notificaciones - Listar",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": "{{baseUrl}}/api/v1/notificaciones"
      }
    }
  ]
}