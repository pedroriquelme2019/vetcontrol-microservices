```gitignore
# Variables de entorno privadas
.env
.env.local
.env.*.local

# Archivo público de ejemplo
!.env.example

# IntelliJ IDEA
.idea/
*.iml
*.ipr
*.iws

# Maven y compilaciones
target/
**/target/

# Compiled class file
*.class

# Log files
*.log
logs/

# BlueJ files
*.ctxt

# Mobile Tools for Java
.mtj.tmp/

# Package files
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# Permitir Maven Wrapper si se agrega al proyecto
!.mvn/wrapper/maven-wrapper.jar

# Archivos temporales del sistema
.DS_Store
Thumbs.db

# Virtual machine crash logs
hs_err_pid*
replay_pid*
```
